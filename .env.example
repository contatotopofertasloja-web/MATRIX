# =============================================================================
# .env.example — Matrix Monorepo
# Copie para .env e preencha os valores reais.
# NUNCA commite o .env com valores reais.
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://meuapp.com   # URL pública do Next.js
WEB_URL=https://meuapp.com               # Usado pelo Fastify para CORS

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...         # Nunca expor no frontend

# -----------------------------------------------------------------------------
# Banco de dados (Supabase / PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:[SENHA]@db.xxxx.supabase.co:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[SENHA]@db.xxxx.supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...            # sk_test_... em desenvolvimento
STRIPE_WEBHOOK_SECRET=whsec_...

# IDs dos preços criados no dashboard do Stripe
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_YEARLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...
STRIPE_PRICE_ENTERPRISE_YEARLY=price_...

# -----------------------------------------------------------------------------
# Redis (usado pelo matrix-wpp)
# -----------------------------------------------------------------------------
REDIS_URL=redis://127.0.0.1:6379

# -----------------------------------------------------------------------------
# Matrix WhatsApp bot (matrix-wpp)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
BOT_DEFAULT=nome-do-bot-padrao
