{
  "name": "matrix-monorepo",
  "private": true,
  "version": "2.0.1",
  "description": "Matrix — fábrica de SaaS + bots de WhatsApp com IA",
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "matrix:dev": "cross-env NODE_ENV=development nodemon src/index.js",
    "matrix:start": "node src/index.js",
    "matrix:init": "node tools/scaffold-bot.mjs init",
    "matrix:add": "node tools/scaffold-bot.mjs add",
    "sanity:settings": "node scripts/sanity-check.mjs",
    "sanity:flows": "node scripts/check-flows-static.mjs",
    "sanity:all": "npm run sanity:settings && npm run sanity:flows"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@whiskeysockets/baileys": "6.7.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "ioredis": "^5.3.2",
    "morgan": "^1.10.0",
    "node-fetch": "^3.3.2",
    "nodemailer": "^6.9.14",
    "openai": "^4.0.0",
    "pino": "^9.0.0",
    "qrcode": "^1.5.4",
    "redis": "^4.6.13",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "nodemon": "^3.1.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "license": "MIT",
  "author": "Matrix Project Team"
}
